{
  "name": "@square2-inc/adaptive-caret",
  "version": "0.1.0",
  "description": "Adaptive Caret by Square² — custom cursor that morphs into a text caret (sizes, colors, transitions, selection).",
  "license": "MIT",
  "author": "Square² (https://square2.pt)",
  "keywords": [
    "square2",
    "square²",
    "cursor",
    "caret",
    "custom-cursor",
    "accessibility",
    "dom",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Square2-Inc/AdaptiveCaret.git"
  },
  "homepage": "https://square2.pt",
  "bugs": {
    "url": "https://github.com/Square2-Inc/AdaptiveCaret/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  }
}
